<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         PALETA
         ============================================================ -->
    <Color x:Key="AccentColor">#2563EB</Color>
    <SolidColorBrush x:Key="Accent" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentHover" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentPressed" Color="#1E40AF"/>
    <SolidColorBrush x:Key="AccentSoft" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="WindowBg" Color="#F1F4FB"/>
    <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorder" Color="#E5EAF3"/>
    <SolidColorBrush x:Key="InputBorder" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="TextMain" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
    <SolidColorBrush x:Key="SidebarBg" Color="#0B1220"/>
    <SolidColorBrush x:Key="Danger" Color="#DC2626"/>
    <SolidColorBrush x:Key="Success" Color="#16A34A"/>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#6366F1" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0B1220" Offset="0"/>
        <GradientStop Color="#101A30" Offset="0.6"/>
        <GradientStop Color="#131E38" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ProgressGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================================
         CARD DE APLICATIVO (ToggleButton selecionável)
         ============================================================ -->
    <Style x:Key="AppCard" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="196"/>
        <Setter Property="Height" Value="96"/>
        <Setter Property="Margin" Value="0,0,14,14"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="shadow" CornerRadius="16" Background="#FFFFFF" Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#3B82F6" BlurRadius="22" ShadowDepth="0" Opacity="0.28"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="bg" CornerRadius="16" Background="{StaticResource CardBg}"
                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1.5"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="iconWrap" Grid.Column="0" Width="46" Height="46" CornerRadius="12"
                                        Background="{StaticResource AccentSoft}" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets"
                                               FontSize="21" Foreground="{StaticResource Accent}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Content}" FontSize="14.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                    <TextBlock x:Name="sub" Text="Clique para incluir" FontSize="11.5"
                                               Foreground="{StaticResource TextMuted}" TextWrapping="NoWrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- selo de selecionado -->
                        <Border x:Name="check" Width="26" Height="26" CornerRadius="13" Background="{StaticResource AccentGradient}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-7,-7,0"
                                RenderTransformOrigin="0.5,0.5" Opacity="0">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="cksc" ScaleX="0.4" ScaleY="0.4"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect Color="#2563EB" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentSoft}"/>
                            <Setter TargetName="iconWrap" Property="Background" Value="{StaticResource AccentGradient}"/>
                            <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            <Setter TargetName="sub" Property="Text" Value="Incluído ✓"/>
                            <Setter TargetName="sub" Property="Foreground" Value="{StaticResource Accent}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="check" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="cksc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.7" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="cksc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.7" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="check" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="cksc" Storyboard.TargetProperty="ScaleX" To="0.4" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="cksc" Storyboard.TargetProperty="ScaleY" To="0.4" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Chip de app selecionado (mostra o que está incluído + botão remover) -->
    <Style x:Key="AppChipRemove" TargetType="Button">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Width="18" Height="18" CornerRadius="9" Background="#00000000">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Danger}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Segmento (RadioButton em forma de pílula, p/ Online/Offline etc.) -->
    <Style x:Key="Segment" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="b" CornerRadius="9" Padding="16,9" Background="{StaticResource CardBg}"
                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1.5">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource AccentSoft}"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         TIPOGRAFIA
         ============================================================ -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ============================================================
         BOTÕES (hover animado + leve zoom)
         ============================================================ -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" CornerRadius="9" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <SolidColorBrush x:Name="bg" Color="#2563EB"/>
                        </Border.Background>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="Color"
                                                        To="#1D4ED8" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="Color"
                                                        To="#2563EB" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="Color"
                                                        To="#1E40AF" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="0.98" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="0.98" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Background" Value="#94A3B8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botão secundário (contorno) -->
    <Style x:Key="Secondary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" CornerRadius="9" BorderThickness="1" Padding="{TemplateBinding Padding}"
                            Background="{StaticResource CardBg}" BorderBrush="{StaticResource InputBorder}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource AccentSoft}"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botão de ação grande (CTA): gradiente + brilho no hover -->
    <Style x:Key="Cta" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="24,13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <!-- brilho (sem filhos: não borra o texto) -->
                        <Border x:Name="glow" CornerRadius="11" Background="{StaticResource AccentGradient}" Opacity="0">
                            <Border.Effect>
                                <BlurEffect Radius="18"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="b" CornerRadius="11" Background="{StaticResource AccentGradient}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0.55" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1.025" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1.025" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="0.98" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="0.98" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Background" Value="#94A3B8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         CAMPOS DE TEXTO
         ============================================================ -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="Background" Value="{StaticResource CardBg}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            <Setter TargetName="b" Property="BorderThickness" Value="1.6"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="#94A3B8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Background" Value="#F1F5F9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ============================================================
         CHECKBOX / RADIO modernos (marcação animada)
         ============================================================ -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="box" Width="19" Height="19" CornerRadius="6" BorderThickness="1.6"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush x:Name="bg" Color="Transparent"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="bd" Color="#94A3B8"/>
                            </Border.BorderBrush>
                            <Path x:Name="check" Data="M 4,10 L 8,14 L 15,5" Stroke="White" StrokeThickness="2.4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  RenderTransformOrigin="0.5,0.5" Opacity="0">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="checkScale" ScaleX="0.4" ScaleY="0.4"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="Color" To="#2563EB" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="Color" To="#2563EB" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="check" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="checkScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="checkScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bg" Storyboard.TargetProperty="Color" To="Transparent" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="Color" To="#94A3B8" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="check" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="checkScale" Storyboard.TargetProperty="ScaleX" To="0.4" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="checkScale" Storyboard.TargetProperty="ScaleY" To="0.4" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#2563EB" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="ring" Width="19" Height="19" CornerRadius="10" BorderThickness="1.6"
                                Background="{StaticResource CardBg}" VerticalAlignment="Center">
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="bd" Color="#94A3B8"/>
                            </Border.BorderBrush>
                            <Ellipse x:Name="dot" Width="9" Height="9" Fill="{StaticResource Accent}"
                                     RenderTransformOrigin="0.5,0.5" Opacity="0">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="dotScale" ScaleX="0.3" ScaleY="0.3"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="Color" To="#2563EB" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="dot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.7"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.7"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="Color" To="#94A3B8" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="dot" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleX" To="0.3" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleY" To="0.3" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         GROUPBOX = cartão com sombra (sombra em camada separada
         para não borrar o texto)
         ============================================================ -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Border CornerRadius="14" Background="{StaticResource CardBg}">
                            <Border.Effect>
                                <DropShadowEffect Color="#0F172A" BlurRadius="18" ShadowDepth="2" Direction="270" Opacity="0.07"/>
                            </Border.Effect>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="14"
                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="18">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="4" Height="16" CornerRadius="2" Background="{StaticResource AccentGradient}"
                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{TemplateBinding Header}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMain}"/>
                                </StackPanel>
                                <ContentPresenter/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         NAVEGAÇÃO LATERAL (TabControl + TabItem)
         ============================================================ -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" IsItemsHost="True" Margin="10,4,10,0"/>
                        <Border Grid.Column="1" Background="Transparent">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="#8FA3C4"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid Margin="0,3">
                        <!-- fundo selecionado (gradiente) -->
                        <Border x:Name="selBg" CornerRadius="10" Background="{StaticResource AccentGradient}" Opacity="0"/>
                        <!-- fundo hover -->
                        <Border x:Name="hoverBg" CornerRadius="10" Background="#1B2A47" Opacity="0"/>
                        <Border Padding="14,11">
                            <StackPanel Orientation="Horizontal" x:Name="content">
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="tx" X="0"/>
                                </StackPanel.RenderTransform>
                                <!-- ícone (glifo Segoe MDL2 vindo do Tag) -->
                                <TextBlock Text="{TemplateBinding Tag}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" Margin="0,0,11,0"/>
                                <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="selBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="tx" Storyboard.TargetProperty="X" To="4" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="selBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="tx" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="#DBEAFE"/>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Página de conteúdo: entra com fade + deslize -->
    <Style x:Key="TabPage" TargetType="StackPanel">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.28"/>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                         From="16" To="0" Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         COMBOBOX moderno
         ============================================================ -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="b" CornerRadius="7" Padding="{TemplateBinding Padding}" Margin="4,1" Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#EFF4FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource AccentSoft}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="Background" Value="{StaticResource CardBg}"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="tb" Background="{StaticResource CardBg}" CornerRadius="8"
                                            BorderBrush="{StaticResource InputBorder}" BorderThickness="1">
                                        <Path x:Name="arrow" Data="M 0,0 L 4.5,4.5 L 9,0" Stroke="#64748B" StrokeThickness="1.8"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform><RotateTransform x:Name="arrowRot" Angle="0"/></Path.RenderTransform>
                                        </Path>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="tb" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="tb" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="arrowRot" Storyboard.TargetProperty="Angle" To="180" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="arrowRot" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="11,0,30,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                               AllowsTransparency="True" PopupAnimation="Slide" StaysOpen="False">
                            <Border Background="{StaticResource CardBg}" CornerRadius="10" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                    MinWidth="{TemplateBinding ActualWidth}" MaxHeight="280" Margin="0,4,12,12" Padding="0,4">
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.18"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         PROGRESSBAR (gradiente animado + modo indeterminado pulsante)
         ============================================================ -->
    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Background" Value="#E2E8F0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="PART_Track" SnapsToDevicePixels="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                        <Border x:Name="PART_Indicator" Background="{StaticResource ProgressGradient}"
                                CornerRadius="6" HorizontalAlignment="Left"/>
                        <!-- pulso do modo indeterminado -->
                        <Border x:Name="pulse" Background="{StaticResource ProgressGradient}" CornerRadius="6" Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="pulseSb">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="pulse" Storyboard.TargetProperty="Opacity"
                                                         From="0.2" To="0.75" Duration="0:0:0.7"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="pulseSb"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         DATAGRID
         ============================================================ -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource CardBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
        <Setter Property="RowBackground" Value="{StaticResource CardBg}"/>
        <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="RowHeight" Value="34"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ColumnHeaderHeight" Value="36"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="Foreground" Value="#475569"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
    </Style>
    <Style TargetType="DataGridRow">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F1F5F9"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         EXPANDER (seta girando)
         ============================================================ -->
    <Style TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Cursor="Hand" Focusable="False">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="#F8FAFC" CornerRadius="9" BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1" Padding="12,9">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="chev" Data="M 0,0 L 4.5,4.5 L 0,9" Stroke="{StaticResource Accent}" StrokeThickness="2"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center"
                                                  Margin="2,0,10,0" RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform><RotateTransform x:Name="rot" Angle="0"/></Path.RenderTransform>
                                            </Path>
                                            <ContentPresenter VerticalAlignment="Center" TextElement.FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="rot" Storyboard.TargetProperty="Angle" To="90" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="rot" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ContentPresenter Content="{TemplateBinding Header}"/>
                        </ToggleButton>
                        <ContentPresenter x:Name="body" Visibility="Collapsed"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="body" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         SCROLLBAR fina e discreta
         ============================================================ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="th" Background="#C3CDDD" CornerRadius="4" Margin="2,1"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="th" Property="Background" Value="#94A3B8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="th" Background="#C3CDDD" CornerRadius="4" Margin="1,2"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="th" Property="Background" Value="#94A3B8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         TOOLTIP escuro arredondado
         ============================================================ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#0F172A"/>
        <Setter Property="Foreground" Value="#E2E8F0"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            MaxWidth="420" TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
