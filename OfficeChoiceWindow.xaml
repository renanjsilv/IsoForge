<Window x:Class="IsoForge.OfficeChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Office 365" Icon="icon.ico"
        Width="600" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBg}">
    <StackPanel Margin="24">
        <TextBlock Text="Como o Office deve ser instalado?" FontSize="19" FontWeight="SemiBold"/>
        <TextBlock Foreground="{StaticResource TextMuted}" Margin="0,4,0,18" TextWrapping="Wrap"
                   Text="Escolha entre embutir o Office dentro da ISO (offline) ou deixar cada máquina baixá-lo da internet (online)."/>

        <Button Click="Offline_Click" HorizontalContentAlignment="Stretch" Padding="18" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="⬇  Offline — embutir na ISO (recomendado)" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Foreground="#DBEAFE" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="Baixa o Office agora (~3,5 GB) e coloca dentro da ISO. Cada máquina instala o Office sem precisar de internet e mais rápido no primeiro logon. A ISO final fica ~4 GB maior."/>
            </StackPanel>
        </Button>

        <Button Click="Online_Click" Style="{StaticResource Secondary}" HorizontalContentAlignment="Stretch" Padding="18" Margin="0,0,0,4">
            <StackPanel>
                <TextBlock Text="🌐  Online — baixar em cada máquina" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                <TextBlock Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="A ISO leva só o instalador leve (~7 MB). Cada máquina baixa o Office (~3,5 GB) da internet no primeiro logon — mais leve na ISO, mas exige internet no computador de destino."/>
            </StackPanel>
        </Button>

        <Button Click="Cancel_Click" Content="Cancelar" Style="{StaticResource Secondary}"
                HorizontalAlignment="Right" Margin="0,10,0,0" Padding="18,8"/>
    </StackPanel>
</Window>
